{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          // <--- Crucial pour le support ESM dans Node
    "moduleResolution": "NodeNext", // <--- Crucial pour trouver les modules
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}